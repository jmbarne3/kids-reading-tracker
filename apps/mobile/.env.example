# Copy this file to .env and fill in the values for your environment.
# .env is git-ignored; .env.example is committed as documentation.
#
# Expo exposes variables prefixed with EXPO_PUBLIC_ to the JS bundle at build time.
# See: https://docs.expo.dev/guides/environment-variables/

# Base URL of the Django API
# iOS Simulator:    http://localhost:8000
# Android Emulator: http://10.0.2.2:8000
# Physical device:  http://<your-machine-LAN-IP>:8000
# Production:       https://api.yourdomain.com
EXPO_PUBLIC_API_URL=http://localhost:8000
