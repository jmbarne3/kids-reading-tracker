# Copy this file to .env and fill in the values for your environment.
# .env is git-ignored; .env.example is committed as documentation.

# ── Security ──────────────────────────────────────────────────────────────────
# Generate a strong key for production: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=django-insecure-replace-me-in-production

# Set to False in production
DEBUG=True

# Comma-separated list of allowed hostnames (e.g. myapp.com,www.myapp.com)
# Leave empty to allow none (DEBUG=False requires at least one entry)
ALLOWED_HOSTS=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins when DEBUG=False
# (e.g. https://myapp.com,https://www.myapp.com)
CORS_ALLOWED_ORIGINS=

# ── Database ──────────────────────────────────────────────────────────────────
# Absolute path to the SQLite database file.
# Defaults to <BASE_DIR>/db.sqlite3 when unset.
# DB_PATH=/data/db.sqlite3

# ── Social Auth ───────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
APPLE_APP_ID=
